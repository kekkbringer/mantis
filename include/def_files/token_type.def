/* X-macro list of all binary operators of the AST. */
// internal tokens
X(None)
X(EOF_)

// token classes
X(Identifier)
X(Number_constant)

// operators and special character
X(Semicolon)
X(Plus)
X(Minus)
X(Comma)
X(Increment)
X(Decrement)
X(Assign)
X(Open_parenthesis)
X(Close_parenthesis)
X(Open_brace)
X(Close_brace)
X(Complement)
X(Times)
X(Slash)
X(Remainder)
X(Bit_and)
X(Bit_or)
X(Bit_xor)
X(Shift_left)
X(Shift_right)
X(Less)
X(Less_equal)
X(Greater)
X(Greater_equal)
X(Equal)
X(Not_equal)
X(Not)
X(And)
X(Or)
X(Compound_add)
X(Compound_subtract)
X(Compound_multiply)
X(Compound_divide)
X(Compound_remainder)
X(Compound_and)
X(Compound_or)
X(Compound_xor)
X(Compound_shiftl)
X(Compound_shiftr)
X(Colon)
X(Question_mark)

